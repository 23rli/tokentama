{
  "compilerOptions": {
    "composite": false,
    "noEmit": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "types": ["node", "vite/client", "electron-vite/node"],
    "paths": {
      "@ecoprompt/shared-types": ["../../packages/shared-types/src/index.ts"],
      "@ecoprompt/scoring-engine": ["../../packages/scoring-engine/src/index.ts"],
      "@ecoprompt/ingestion": ["../../packages/ingestion/src/index.ts"],
      "@ecoprompt/llm-adapters": ["../../packages/llm-adapters/src/index.ts"],
      "@shared/*": ["./src/shared/*"]
    }
  },
  "include": ["src", "electron.vite.config.ts"]
}
