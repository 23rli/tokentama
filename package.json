{
  "name": "tokentama",
  "displayName": "Token Lens",
  "description": "Real-time cost visibility and forecasting for GitHub Copilot: see what each chat spends, where the tokens go, and what your next turn will cost — live, local, read-only.",
  "version": "0.4.9",
  "publisher": "tokentama",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/23rli/tokentama.git"
  },
  "homepage": "https://github.com/23rli/tokentama#readme",
  "bugs": {
    "url": "https://github.com/23rli/tokentama/issues"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Visualization",
    "Education",
    "Other"
  ],
  "keywords": [
    "ai",
    "copilot",
    "tokens",
    "cost",
    "forecast",
    "context"
  ],
  "icon": "media/icon.png",
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "tokentama",
          "title": "Token Lens",
          "icon": "media/tokentama-icon.svg"
        }
      ]
    },
    "views": {
      "tokentama": [
        {
          "type": "webview",
          "id": "tokentama.dashboard",
          "name": "Token Lens"
        }
      ]
    },
    "commands": [
      {
        "command": "tokentama.openDashboard",
        "title": "Open dashboard",
        "category": "Token Lens"
      },
      {
        "command": "tokentama.toggleCapture",
        "title": "Toggle passive capture",
        "category": "Token Lens"
      },
      {
        "command": "tokentama.compactSession",
        "title": "Compact chat (fresh chat + summary)",
        "category": "Token Lens",
        "icon": "$(combine)"
      },
      {
        "command": "tokentama.diagnostics",
        "title": "Show capture diagnostics",
        "category": "Token Lens",
        "icon": "$(info)"
      },
      {
        "command": "tokentama.captureSelfTest",
        "title": "Capture self-test (what is it reading?)",
        "category": "Token Lens",
        "icon": "$(checklist)"
      }
    ],
    "menus": {
      "view/title": []
    },
    "configuration": {
      "title": "Token Lens",
      "properties": {
        "tokentama.passiveCapture.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Passively read VS Code Copilot chat sessions to track token usage. Read-only."
        },
        "tokentama.impact.usdPerMillionTokens": {
          "type": "number",
          "default": 0.58,
          "description": "Blended, cache-inclusive US dollars per 1,000,000 tokens — the preferred $ cost basis. Set this to YOUR effective rate for an accurate figure, or 0 to fall back to the credit-based estimate."
        },
        "tokentama.impact.usdPerCredit": {
          "type": "number",
          "default": 0,
          "description": "US dollars per Copilot AI credit (AIC). Only used when 'usdPerMillionTokens' is 0."
        },
        "tokentama.capture.mode": {
          "type": "string",
          "enum": [
            "hybrid",
            "event",
            "disk"
          ],
          "enumDescriptions": [
            "Live event path reconciled against on-disk sessions for real tokens (recommended).",
            "Live event path only — no on-disk watcher.",
            "On-disk watcher only."
          ],
          "default": "hybrid",
          "description": "How Token Lens captures Copilot token usage."
        },
        "tokentama.capture.scope": {
          "type": "string",
          "enum": [
            "window",
            "all"
          ],
          "enumDescriptions": [
            "Capture only THIS window's Copilot sessions.",
            "Track every Copilot chat across all windows."
          ],
          "default": "all",
          "description": "Which Copilot sessions live capture watches."
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "package": "node esbuild.mjs --production",
    "vsce:package": "vsce package",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "bench": "node scripts/run-bench.mjs",
    "bench:history": "node scripts/run-bench.mjs bench-history.ts",
    "bench:human": "node scripts/run-bench.mjs bench-human.ts",
    "bench:cache": "node scripts/run-bench.mjs bench-cache.ts",
    "bench:forecast": "node scripts/run-bench.mjs bench-forecast.ts",
    "bench:forecast:lab": "node scripts/run-bench.mjs bench-forecast-lab.ts",
    "bench:forecast:prompt": "node scripts/run-bench.mjs bench-forecast-prompt.ts",
    "bench:forecast:robust": "node scripts/run-bench.mjs bench-forecast-robust.ts",
    "bench:forecast:improve": "node scripts/run-bench.mjs bench-forecast-improve.ts",
    "bench:forecast:toolsize": "node scripts/run-bench.mjs bench-forecast-toolsize.ts",
    "probe:context": "node scripts/run-bench.mjs probe-context.ts",
    "probe:viability": "node scripts/run-bench.mjs probe-viability.ts"
  },
  "dependencies": {
    "preact": "^10.25.4"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.2.1",
    "esbuild": "^0.24.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
