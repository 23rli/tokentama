{
  "name": "tokentama",
  "displayName": "Token Lens",
  "description": "A private, local ledger for your personal AI usage: measured tokens, native charges, costs, models, projects, data coverage, and live GitHub Copilot forecasting.",
  "version": "0.8.3",
  "publisher": "tokentama",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/t-richarli_microsoft/tokentama.git"
  },
  "homepage": "https://github.com/t-richarli_microsoft/tokentama#readme",
  "bugs": {
    "url": "https://github.com/t-richarli_microsoft/tokentama/issues"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Visualization",
    "Education",
    "Other"
  ],
  "keywords": [
    "ai",
    "copilot",
    "tokens",
    "cost",
    "forecast",
    "context",
    "ledger",
    "finops"
  ],
  "icon": "media/icon.png",
  "galleryBanner": {
    "color": "#181818",
    "theme": "dark"
  },
  "qna": "marketplace",
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "tokenlens",
          "title": "Token Lens",
          "icon": "media/tokentama-icon.svg"
        }
      ]
    },
    "views": {
      "tokenlens": [
        {
          "type": "webview",
          "id": "tokenlens.dashboard",
          "name": "Token Lens"
        }
      ]
    },
    "commands": [
      {
        "command": "tokenlens.openDashboard",
        "title": "Open dashboard",
        "category": "Token Lens"
      },
      {
        "command": "tokenlens.toggleCapture",
        "title": "Toggle passive capture",
        "category": "Token Lens"
      },
      {
        "command": "tokenlens.pinChat",
        "title": "Pin to this chat",
        "category": "Token Lens"
      },
      {
        "command": "tokenlens.unpinChat",
        "title": "Unpin chat",
        "category": "Token Lens"
      },
      {
        "command": "tokenlens.diagnostics",
        "title": "Show capture diagnostics",
        "category": "Token Lens"
      },
      {
        "command": "tokenlens.captureSelfTest",
        "title": "Capture self-test",
        "category": "Token Lens"
      },
      {
        "command": "tokenlens.exportLedger",
        "title": "Export local usage ledger",
        "category": "Token Lens"
      },
      {
        "command": "tokenlens.clearLedger",
        "title": "Clear local usage ledger",
        "category": "Token Lens"
      },
      {
        "command": "tokenlens.rebuildLedger",
        "title": "Rebuild local usage ledger from all Copilot history",
        "category": "Token Lens"
      },
      {
        "command": "tokenlens.ledgerDiagnostics",
        "title": "Show local ledger diagnostics",
        "category": "Token Lens"
      }
    ],
    "configuration": {
      "title": "Token Lens",
      "properties": {
        "tokenlens.passiveCapture.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Passively read VS Code Copilot chat sessions to track token usage. Read-only. When off, automatic reads stop; explicit diagnostics/self-test commands can still read on demand."
        },
        "tokenlens.impact.usdPerMillionTokens": {
          "type": "number",
          "minimum": 0,
          "default": 0.58,
          "description": "Blended, cache-inclusive US dollars per 1,000,000 tokens — the preferred $ cost basis. Set this to YOUR effective rate for an accurate figure, or 0 to fall back to the credit-based estimate."
        },
        "tokenlens.impact.usdPerCredit": {
          "type": "number",
          "minimum": 0,
          "default": 0,
          "description": "US dollars per Copilot AI credit (AIC). Only used when 'usdPerMillionTokens' is 0."
        },
        "tokenlens.capture.scope": {
          "type": "string",
          "enum": [
            "window",
            "all"
          ],
          "enumDescriptions": [
            "Only THIS window's workspace (recommended — each window stays isolated).",
            "Follow the newest Copilot chat across ALL windows (can inherit another window's chat)."
          ],
          "default": "window",
          "description": "Which Copilot sessions Token Lens tracks. 'window' keeps each window isolated; 'all' follows the newest chat anywhere."
        },
        "tokenlens.businessTools.enabled": {
          "type": "boolean",
          "scope": "window",
          "default": false,
          "markdownDescription": "Enable local business-tool and workflow attribution. This is independent of core Copilot token capture and is off by default."
        },
        "tokenlens.businessTools.enabledGroups": {
          "type": "array",
          "scope": "window",
          "default": [],
          "uniqueItems": true,
          "items": {
            "type": "string"
          },
          "markdownDescription": "Business-tool groups to track. Built-ins: `fde-hq` for FD&E HQ's known services and workflows, and `all-mcp` as a catch-all. Custom group IDs from `tokenlens.businessTools.customGroups` can also be used."
        },
        "tokenlens.businessTools.customGroups": {
          "type": "object",
          "scope": "window",
          "default": {},
          "markdownDescription": "Optional reusable tool groups. Each group can define service match substrings and workflow-name substrings; enable it through `tokenlens.businessTools.enabledGroups`. User-supplied regular expressions are not executed.",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              },
              "description": {
                "type": "string"
              },
              "mcpOnly": {
                "type": "boolean",
                "default": false
              },
              "workflows": {
                "type": "array",
                "uniqueItems": true,
                "items": {
                  "type": "string"
                }
              },
              "services": {
                "type": "object",
                "additionalProperties": {
                  "type": "object",
                  "required": [
                    "match"
                  ],
                  "properties": {
                    "name": {
                      "type": "string"
                    },
                    "match": {
                      "type": "array",
                      "minItems": 1,
                      "uniqueItems": true,
                      "items": {
                        "type": "string"
                      }
                    }
                  },
                  "additionalProperties": false
                }
              }
            },
            "additionalProperties": false
          }
        },
        "tokenlens.businessTools.rates": {
          "type": "object",
          "scope": "window",
          "default": {},
          "markdownDescription": "Optional local marginal-cost assumptions for MCP-backed business tools. Key by Token Lens service ID (for example `azure-devops`, `workiq`, `kusto`, `fabric`) or by an exact transcript tool name. A number means USD per call; an object can set `usdPerCall` and/or `usdPerMinute`. Use `0` to mark an included/licensed service as priced at zero. Unknown calls remain visibly unpriced; no rate is inferred or uploaded.",
          "additionalProperties": {
            "oneOf": [
              {
                "type": "number",
                "minimum": 0
              },
              {
                "type": "object",
                "properties": {
                  "usdPerCall": {
                    "type": "number",
                    "minimum": 0
                  },
                  "usdPerMinute": {
                    "type": "number",
                    "minimum": 0
                  }
                },
                "additionalProperties": false
              }
            ]
          }
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "package": "node esbuild.mjs --production",
    "vsce:package": "vsce package --no-dependencies",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "bench": "node scripts/run-bench.mjs",
    "bench:history": "node scripts/run-bench.mjs bench-history.ts",
    "bench:human": "node scripts/run-bench.mjs bench-human.ts",
    "bench:cache": "node scripts/run-bench.mjs bench-cache.ts",
    "bench:forecast": "node scripts/run-bench.mjs bench-forecast.ts",
    "bench:forecast:lab": "node scripts/run-bench.mjs bench-forecast-lab.ts",
    "bench:forecast:prompt": "node scripts/run-bench.mjs bench-forecast-prompt.ts",
    "bench:forecast:robust": "node scripts/run-bench.mjs bench-forecast-robust.ts",
    "bench:forecast:improve": "node scripts/run-bench.mjs bench-forecast-improve.ts",
    "bench:forecast:toolsize": "node scripts/run-bench.mjs bench-forecast-toolsize.ts",
    "probe:context": "node scripts/run-bench.mjs probe-context.ts",
    "probe:viability": "node scripts/run-bench.mjs probe-viability.ts",
    "bench:ledger": "node scripts/run-bench.mjs bench-ledger.ts"
  },
  "dependencies": {
    "preact": "^10.29.4"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.2.1",
    "esbuild": "^0.28.1",
    "typescript": "^5.7.2",
    "vitest": "^4.1.9"
  }
}
