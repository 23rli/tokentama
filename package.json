{
  "name": "tokentama",
  "displayName": "Tokentama",
  "description": "An AI-efficiency companion that scores prompt waste, coaches better prompts, and grows a tamagotchi ecosystem that thrives when you prompt efficiently.",
  "version": "0.1.0",
  "publisher": "tokentama",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/tokentama.git"
  },
  "homepage": "https://github.com/your-org/tokentama#readme",
  "bugs": {
    "url": "https://github.com/your-org/tokentama/issues"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Visualization",
    "Education",
    "Other"
  ],
  "keywords": [
    "ai",
    "copilot",
    "tokens",
    "sustainability",
    "prompt",
    "efficiency",
    "coaching"
  ],
  "icon": "media/icon.png",
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "tokentama",
          "title": "Tokentama",
          "icon": "media/tokentama-icon.svg"
        }
      ]
    },
    "views": {
      "tokentama": [
        {
          "type": "webview",
          "id": "tokentama.dashboard",
          "name": "Tokentama"
        }
      ]
    },
    "commands": [
      {
        "command": "tokentama.scorePrompt",
        "title": "Score this prompt",
        "category": "Tokentama",
        "icon": "$(beaker)"
      },
      {
        "command": "tokentama.openDashboard",
        "title": "Open Tokentama dashboard",
        "category": "Tokentama"
      },
      {
        "command": "tokentama.toggleCapture",
        "title": "Toggle passive capture",
        "category": "Tokentama"
      },
      {
        "command": "tokentama.resetEcosystem",
        "title": "Reset ecosystem",
        "category": "Tokentama",
        "icon": "$(debug-restart)"
      },
      {
        "command": "tokentama.rescan",
        "title": "Scan recent Copilot prompts",
        "category": "Tokentama",
        "icon": "$(sync)"
      },
      {
        "command": "tokentama.diagnostics",
        "title": "Show capture diagnostics",
        "category": "Tokentama",
        "icon": "$(info)"
      },
      {
        "command": "tokentama.runDemo",
        "title": "Run Tokentama demo",
        "category": "Tokentama",
        "icon": "$(play-circle)"
      },
      {
        "command": "tokentama.setLlmApiKey",
        "title": "Set coaching LLM API key",
        "category": "Tokentama"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "tokentama.rescan",
          "when": "view == tokentama.dashboard",
          "group": "navigation@0"
        },
        {
          "command": "tokentama.diagnostics",
          "when": "view == tokentama.dashboard",
          "group": "navigation@3"
        },
        {
          "command": "tokentama.runDemo",
          "when": "view == tokentama.dashboard",
          "group": "navigation@4"
        },
        {
          "command": "tokentama.scorePrompt",
          "when": "view == tokentama.dashboard",
          "group": "navigation@1"
        },
        {
          "command": "tokentama.resetEcosystem",
          "when": "view == tokentama.dashboard",
          "group": "navigation@2"
        }
      ]
    },
    "chatParticipants": [
      {
        "id": "tokentama.chat",
        "name": "tokentama",
        "fullName": "Tokentama",
        "description": "Score a prompt's efficiency and suggest a leaner version",
        "isSticky": false
      }
    ],
    "configuration": {
      "title": "Tokentama",
      "properties": {
        "tokentama.passiveCapture.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Passively read VS Code Copilot chat sessions to score prompts automatically. Experimental and read-only."
        },
        "tokentama.coaching.llmProvider": {
          "type": "string",
          "enum": [
            "none",
            "openai",
            "azure-openai"
          ],
          "default": "none",
          "description": "LLM provider for coaching tips. 'none' uses the offline heuristic coach."
        },
        "tokentama.coaching.endpoint": {
          "type": "string",
          "default": "",
          "description": "LLM endpoint URL (for openai / azure-openai)."
        },
        "tokentama.coaching.model": {
          "type": "string",
          "default": "gpt-4o-mini",
          "description": "Model or deployment name used for coaching."
        },
        "tokentama.sustainability.whPerThousandTokens": {
          "type": "number",
          "default": 0.4,
          "description": "Estimated watt-hours consumed per 1,000 tokens, used for the sustainability estimate."
        },
        "tokentama.sustainability.gridGramsCo2PerKwh": {
          "type": "number",
          "default": 400,
          "description": "Grid carbon intensity (gCO2e per kWh) for the sustainability estimate."
        },
        "tokentama.impact.co2GramsPer1kTokens": {
          "type": "number",
          "default": 0.11,
          "description": "Estimated grams of CO2e per 1,000 tokens, used for the headline environmental impact."
        },
        "tokentama.impact.waterMlPer1kTokens": {
          "type": "number",
          "default": 2,
          "description": "Estimated millilitres of water per 1,000 tokens, used for the headline environmental impact."
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "package": "node esbuild.mjs --production",
    "vsce:package": "vsce package",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "preact": "^10.25.4"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.2.1",
    "esbuild": "^0.24.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
