# ─────────────────────────────────────────────────────────────
# Tokentama — environment configuration (example)
# Copy to .env and fill in. Everything works locally WITHOUT these.
# ─────────────────────────────────────────────────────────────

# --- Backend API ---
ECO_API_PORT=7071
# The desktop widget reads ECO_API_URL to locate the backend.
ECO_API_URL=http://localhost:7071/api

# --- LLM coach (optional). If unset, the deterministic heuristic coach is used. ---
# Provider: "none" | "azure-openai" | "foundry" | "openai"
ECO_LLM_PROVIDER=none
ECO_LLM_ENDPOINT=
ECO_LLM_API_KEY=
ECO_LLM_DEPLOYMENT=
ECO_LLM_API_VERSION=2024-10-21
ECO_LLM_TIMEOUT_MS=12000

# --- Telemetry (optional). If unset, telemetry is logged to console only. ---
APPLICATIONINSIGHTS_CONNECTION_STRING=

# --- Storage (optional). If unset, an in-memory store is used. ---
# Use "UseDevelopmentStorage=true" for local Azurite.
ECO_STORAGE_CONNECTION_STRING=

# --- Copilot interception (optional override). Auto-detected if unset. ---
ECO_COPILOT_WORKSPACE_STORAGE=
